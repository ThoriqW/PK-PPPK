APP_NAME="Perjanjian Kerja BKPSDMD Kota Palu"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Makassar
APP_URL=http://localhost:8000
APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bkpsdmd_perjanjian
DB_USERNAME=postgres
DB_PASSWORD=postgres

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
SESSION_DOMAIN=localhost

VITE_APP_NAME="${APP_NAME}"

# Default admin credentials seeded at first migrate (change immediately after first login)
SEED_ADMIN_NAME="Administrator BKPSDMD"
SEED_ADMIN_EMAIL=admin@bkpsdmd.palu.go.id
SEED_ADMIN_PASSWORD=ChangeMe!2026

# Public host used in QR codes (must be reachable from outside)
PUBLIC_VERIFY_BASE_URL="${APP_URL}"
